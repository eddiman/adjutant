#!/bin/bash
# tests/run — Test runner for the Adjutant bats suite
#
# Usage:
#   tests/run              # full suite
#   tests/run unit         # unit tests only
#   tests/run integration  # integration tests only
#   tests/run <file.bats>  # single file
#   tests/run --filter "pattern" [tier]
#
# IMPORTANT: The full suite MUST be run with parallelism. Running serially
# causes the suite to exceed typical timeout limits (120–300 s) and will be
# killed before all 583 tests complete. Install GNU parallel first:
#
#   brew install parallel   # macOS
#   apt install parallel    # Debian/Ubuntu

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

UNIT_DIR="${SCRIPT_DIR}/unit"
INT_DIR="${SCRIPT_DIR}/integration"

# ---------------------------------------------------------------------------
# Parallelism: GNU parallel is REQUIRED for the full suite.
# Without it the suite takes too long and will be killed mid-run.
# ---------------------------------------------------------------------------
JOBS_FLAG=""
if command -v parallel >/dev/null 2>&1; then
  JOBS_FLAG="--jobs 8"
else
  echo "ERROR: GNU parallel is not installed." >&2
  echo "       The full suite cannot complete within timeout limits without it." >&2
  echo "       Install it first:  brew install parallel  (macOS)" >&2
  echo "                          apt install parallel   (Linux)" >&2
  echo "" >&2
  echo "       To run a single file without parallel:" >&2
  echo "         bats tests/unit/lockfiles.bats" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
FILTER_FLAG=""
TARGET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --filter|-f)
      FILTER_FLAG="--filter $2"
      shift 2
      ;;
    unit|integration|int)
      TARGET="$1"
      shift
      ;;
    *.bats)
      TARGET="$1"
      shift
      ;;
    *)
      echo "Usage: tests/run [unit|integration|<file.bats>] [--filter <pattern>]" >&2
      exit 1
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Determine target directories / files
# ---------------------------------------------------------------------------
case "${TARGET}" in
  unit)        BATS_ARGS="${UNIT_DIR}" ;;
  integration|int) BATS_ARGS="${INT_DIR}" ;;
  *.bats)      BATS_ARGS="${TARGET}" ;;
  *)           BATS_ARGS="${UNIT_DIR} ${INT_DIR}" ;;  # default: full suite
esac

# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------
echo "Running with parallelism (${JOBS_FLAG})"

# shellcheck disable=SC2086
exec bats ${JOBS_FLAG} ${FILTER_FLAG} ${BATS_ARGS}
