#!/bin/bash
# adjutant — CLI entrypoint
#
# Thin dispatcher that routes subcommands to the appropriate script.
# Replaces remembering individual script paths.
#
# Usage:
#   adjutant start          Start the Telegram listener
#   adjutant stop           Stop the Telegram listener
#   adjutant restart        Restart all services
#   adjutant update         Self-update to the latest release
#   adjutant status         Show system status
#   adjutant pause          Pause Adjutant (soft stop)
#   adjutant resume         Resume from pause
#   adjutant kill           Emergency shutdown
#   adjutant startup        Full startup / recovery
#   adjutant notify "msg"   Send a Telegram notification
#   adjutant screenshot URL Take and send a screenshot
#   adjutant news           Run news briefing
#   adjutant rotate         Archive old journal entries and rotate logs
#   adjutant kb             Knowledge base management (create, list, remove, info, query)
#   adjutant logs           Tail the listener log
#   adjutant doctor         Check health and dependencies
#   adjutant setup          Interactive setup wizard
#   adjutant uninstall      Remove Adjutant from this machine
#   adjutant help           Show this help

set -euo pipefail

# Resolve ADJ_DIR
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/scripts/common/paths.sh"

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
  start)
    exec bash "${ADJ_DIR}/scripts/messaging/telegram/service.sh" start
    ;;

  stop)
    exec bash "${ADJ_DIR}/scripts/messaging/telegram/service.sh" stop
    ;;

  restart)
    exec bash "${ADJ_DIR}/scripts/lifecycle/restart.sh"
    ;;

  update)
    exec bash "${ADJ_DIR}/scripts/lifecycle/update.sh" "$@"
    ;;

  status)
    exec bash "${ADJ_DIR}/scripts/observability/status.sh"
    ;;

  pause)
    exec bash "${ADJ_DIR}/scripts/lifecycle/pause.sh"
    ;;

  resume)
    exec bash "${ADJ_DIR}/scripts/lifecycle/resume.sh"
    ;;

  kill)
    exec bash "${ADJ_DIR}/scripts/lifecycle/emergency_kill.sh"
    ;;

  startup)
    exec bash "${ADJ_DIR}/scripts/lifecycle/startup.sh"
    ;;

  notify)
    if [ -z "${1:-}" ]; then
      echo "Usage: adjutant notify \"message\""
      exit 1
    fi
    exec bash "${ADJ_DIR}/scripts/messaging/telegram/notify.sh" "$@"
    ;;

  screenshot)
    if [ -z "${1:-}" ]; then
      echo "Usage: adjutant screenshot <url> [caption]"
      exit 1
    fi
    exec bash "${ADJ_DIR}/scripts/capabilities/screenshot/screenshot.sh" "$@"
    ;;

  news)
    exec bash "${ADJ_DIR}/scripts/news/briefing.sh"
    ;;

  rotate)
    exec bash "${ADJ_DIR}/scripts/observability/journal_rotate.sh" "$@"
    ;;

  kb)
    KB_ACTION="${1:-help}"
    shift 2>/dev/null || true

    case "$KB_ACTION" in
      create)
        if [ "${1:-}" = "--quick" ]; then
          exec bash "${ADJ_DIR}/scripts/setup/steps/kb_wizard.sh" --quick "$@"
        else
          exec bash "${ADJ_DIR}/scripts/setup/steps/kb_wizard.sh"
        fi
        ;;
      list)
        source "${ADJ_DIR}/scripts/capabilities/kb/manage.sh"
        local_count="$(kb_count)"
        if [ "${local_count}" -eq 0 ]; then
          echo "No knowledge bases registered."
          echo "Create one with: adjutant kb create"
        else
          echo "Registered knowledge bases (${local_count}):"
          echo ""
          printf "  %-20s %-12s %s\n" "NAME" "ACCESS" "DESCRIPTION"
          printf "  %-20s %-12s %s\n" "----" "------" "-----------"
          while IFS=$'\t' read -r name desc path access; do
            printf "  %-20s %-12s %s\n" "${name}" "${access}" "${desc}"
          done < <(kb_list)
        fi
        ;;
      remove)
        if [ -z "${1:-}" ]; then
          echo "Usage: adjutant kb remove <name>"
          exit 1
        fi
        source "${ADJ_DIR}/scripts/capabilities/kb/manage.sh"
        kb_remove "$1"
        echo "Unregistered knowledge base '$1'. Files were NOT deleted."
        ;;
      info)
        if [ -z "${1:-}" ]; then
          echo "Usage: adjutant kb info <name>"
          exit 1
        fi
        source "${ADJ_DIR}/scripts/capabilities/kb/manage.sh"
        kb_info "$1"
        ;;
      query)
        if [ -z "${1:-}" ] || [ -z "${2:-}" ]; then
          echo "Usage: adjutant kb query <name> \"your question\""
          exit 1
        fi
        exec bash "${ADJ_DIR}/scripts/capabilities/kb/query.sh" "$@"
        ;;
      help|--help|-h)
        cat <<'KBEOF'
Knowledge Base Management

Usage: adjutant kb <command> [args]

Commands:
  create              Interactive KB creation wizard
  create --quick ...  Quick create (--name, --path, --desc, --model, --access)
  list                List registered knowledge bases
  remove <name>       Unregister a KB (files are NOT deleted)
  info <name>         Show details about a KB
  query <name> "q"    Query a KB with a question
  help                Show this help
KBEOF
        ;;
      *)
        echo "Unknown kb command: $KB_ACTION"
        echo "Run 'adjutant kb help' for usage."
        exit 1
        ;;
    esac
    ;;

  setup)
    exec bash "${ADJ_DIR}/scripts/setup/wizard.sh" "$@"
    ;;

  uninstall)
    exec bash "${ADJ_DIR}/scripts/setup/uninstall.sh" "$@"
    ;;

  logs)
    # Prefer the unified log; fall back to legacy listener log
    LOG_FILE="${ADJ_DIR}/state/adjutant.log"
    [ ! -f "$LOG_FILE" ] && LOG_FILE="${ADJ_DIR}/state/telegram_listener.log"
    if [ ! -f "$LOG_FILE" ]; then
      echo "No log file found. Checked:"
      echo "  ${ADJ_DIR}/state/adjutant.log"
      echo "  ${ADJ_DIR}/state/telegram_listener.log"
      exit 1
    fi
    tail -f "$LOG_FILE"
    ;;

  doctor)
    echo "Adjutant Health Check"
    echo "====================="
    echo ""
    echo "Installation: ${ADJ_DIR}"
    echo "OS:           ${ADJUTANT_OS:-$(uname -s)}"
    echo ""

    # Check dependencies
    echo "Dependencies:"
    for cmd in bash curl jq python3 opencode; do
      if command -v "$cmd" > /dev/null 2>&1; then
        version=$("$cmd" --version 2>&1 | head -1)
        printf "  %-12s %s\n" "$cmd" "OK ($version)"
      else
        printf "  %-12s %s\n" "$cmd" "MISSING"
      fi
    done

    # Optional deps
    echo ""
    echo "Optional:"
    if npx playwright --version > /dev/null 2>&1; then
      printf "  %-12s %s\n" "playwright" "OK"
    else
      printf "  %-12s %s\n" "playwright" "not installed (needed for /screenshot)"
    fi

    # Config files
    echo ""
    echo "Configuration:"
    for f in adjutant.yaml .env identity/soul.md identity/heart.md identity/registry.md news_config.json opencode.json; do
      if [ -f "${ADJ_DIR}/${f}" ]; then
        printf "  %-20s %s\n" "$f" "present"
      else
        printf "  %-20s %s\n" "$f" "MISSING"
      fi
    done

    # Lockfiles
    echo ""
    echo "State:"
    source "${ADJ_DIR}/scripts/common/lockfiles.sh" 2>/dev/null
    if is_killed 2>/dev/null; then
      echo "  Status: KILLED (run 'adjutant startup' to recover)"
    elif is_paused 2>/dev/null; then
      echo "  Status: PAUSED (run 'adjutant resume')"
    else
      echo "  Status: operational"
    fi

    # Listener (delegate to service.sh for authoritative detection)
    listener_status="$(bash "${ADJ_DIR}/scripts/messaging/telegram/service.sh" status 2>/dev/null || echo "Stopped")"
    echo "  Listener: $(echo "${listener_status}" | tr '[:upper:]' '[:lower:]')"
    ;;

  help|--help|-h)
    cat <<'EOF'
Adjutant — Persistent autonomous agent framework

Usage: adjutant <command> [args]

Commands:
  start              Start the Telegram listener
  stop               Stop the Telegram listener
  restart            Restart all services
  update             Self-update to the latest release
  status             Show system status
  pause              Pause Adjutant (soft stop)
  resume             Resume from pause
  kill               Emergency shutdown
  startup            Full startup / recovery from KILLED
  notify "message"   Send a Telegram notification
  screenshot <url>   Take and send a website screenshot
  news               Run the news briefing
  rotate             Archive old journal entries and rotate logs
  kb <command>       Knowledge base management (create, list, remove, info, query)
  logs               Tail the listener log
  doctor             Check health and dependencies
  setup              Interactive setup wizard (--repair for health check)
  uninstall          Remove Adjutant from this machine
  help               Show this help
EOF
    ;;

  *)
    echo "Unknown command: $COMMAND"
    echo "Run 'adjutant help' for usage."
    exit 1
    ;;
esac
