# Adjutant — Telegram Notifications
# 1. Talk to @BotFather on Telegram, create a new bot
# 2. Copy the bot token here
# 3. Send a message to your bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Brave Search API — used by /search command and the agent's bash search tool
# Free tier: 2,000 queries/month. Get a key at https://api.search.brave.com
BRAVE_API_KEY=your-brave-api-key-here

# Nordnet — Portfolio KB
# Used by the portfolio KB's QR login flow (scripts/nordnet_qr_login.sh).
#
# Auth uses BankID (Norway) via Playwright MCP — no password needed.
# To authenticate:
#   1. Send /nordnet-login via Telegram
#   2. Scan the QR code that appears in the chat with the Nordnet app
#   3. Session is saved automatically and lasts ~4 hours
#
# NORDNET_MOCK_WRITES=true intercepts all order placement/cancellation —
# reads always hit the real API. Remove or set to false to trade for real.
# NORDNET_ACCOUNT_ID is auto-discovered during login and cached in
# portfolio-kb/state/nordnet_session.json — you don't need to set this.
# NORDNET_ACCOUNT_ID=optional-override
NORDNET_MOCK_WRITES=true
