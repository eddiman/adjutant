# Adjutant — Telegram Notifications
# 1. Talk to @BotFather on Telegram, create a new bot
# 2. Copy the bot token here
# 3. Send a message to your bot, then visit:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    to find your chat_id
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Brave Search API — used by /search command and the agent's bash search tool
# Free tier: 2,000 queries/month. Get a key at https://api.search.brave.com
BRAVE_API_KEY=your-brave-api-key-here
